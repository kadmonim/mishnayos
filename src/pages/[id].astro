---
import { sql } from '../lib/db';

const { id } = Astro.params;

const rows = await sql`SELECT * FROM saved_links WHERE id = ${id}`;
const record = rows[0];

if (!record) {
  return Astro.redirect('/');
}

const name: string = record.name;
const personName: string | null = record.person_name;
const letters: string = record.letters;
const pageId: string = record.id;
---

<html lang="he" dir="rtl">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;700&display=swap" rel="stylesheet" />
		<title>לימוד משניות לפי אותיות השם {personName || name}</title>
		<meta property="og:title" content={`משניות אותיות ${name}`} />
		<meta property="og:description" content={`לעילוי נשמת ${personName || name}`} />
		<meta property="og:type" content="website" />
		<meta name="description" content={`משניות אותיות ${name} - לעילוי נשמת ${personName || name}`} />
		<style is:global>
			* { box-sizing: border-box; margin: 0; padding: 0; }
			body {
				font-family: 'Heebo', sans-serif;
				background: #faf9f6;
				color: #1a1a1a;
				padding: 2rem 1rem;
				max-width: 720px;
				margin: 0 auto;
			}
			h1 {
				font-size: 1.8rem;
				text-align: center;
				margin-bottom: 0.5rem;
			}
			.subtitle {
				text-align: center;
				color: #666;
				margin-bottom: 2rem;
				font-size: 1.1rem;
			}
			.back-link {
				display: block;
				text-align: center;
				margin-bottom: 1.5rem;
				color: #8b7355;
				text-decoration: none;
			}
			.back-link:hover { text-decoration: underline; }
			#letters {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-bottom: 2rem;
				justify-content: center;
			}
			.letter-badge {
				background: #e8e0d0;
				padding: 0.4rem 0.8rem;
				border-radius: 6px;
				font-size: 1.1rem;
				cursor: pointer;
				border: 2px solid transparent;
				transition: all 0.15s;
			}
			.letter-badge:hover { border-color: #8b7355; }
			.letter-badge.active {
				background: #8b7355;
				color: #fff;
			}
			#loading {
				text-align: center;
				padding: 2rem;
				color: #888;
			}
			.chapter {
				background: #fff;
				border: 1px solid #e0d8c8;
				border-radius: 10px;
				margin-bottom: 1.5rem;
				overflow: hidden;
			}
			.chapter-header {
				background: #f0ebe0;
				padding: 0.75rem 1rem;
				font-weight: bold;
				font-size: 1.1rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.chapter-header .letter-tag {
				background: #8b7355;
				color: #fff;
				padding: 0.2rem 0.6rem;
				border-radius: 4px;
				font-size: 0.9rem;
			}
			.mishnah {
				padding: 0.75rem 1rem;
				border-bottom: 1px solid #f0ebe0;
				line-height: 1.8;
				font-size: 140%;
			}
			.mishnah:last-child { border-bottom: none; }
			.mishnah-num {
				font-weight: bold;
				color: #8b7355;
				margin-left: 0.3rem;
			}
			.bartenura-toggle {
				display: inline-block;
				margin-right: 0.5rem;
				cursor: pointer;
				color: #8b7355;
				font-size: 0.85rem;
				user-select: none;
				border: 1px solid #d4c5a9;
				border-radius: 4px;
				padding: 0.1rem 0.4rem;
			}
			.bartenura-toggle:hover { background: #f0ebe0; }
			.bartenura {
				display: none;
				background: #f9f6ef;
				border-top: 1px dashed #d4c5a9;
				margin-top: 0.5rem;
				padding: 0.6rem 0.8rem;
				line-height: 1.7;
				font-size: 0.82em;
				color: #444;
			}
			.bartenura.open { display: block; }
			.bartenura b { color: #1a1a1a; }
			.error {
				text-align: center;
				color: #c44;
				padding: 1rem;
			}
			.font-bar {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.85rem;
				color: #888;
			}
			.font-bar button {
				padding: 0.25rem 0.6rem;
				font-size: 0.9rem;
				background: #e8e0d0;
				color: #1a1a1a;
				border: none;
				border-radius: 5px;
				min-width: 2rem;
				cursor: pointer;
				font-family: inherit;
			}
			.font-bar button:hover { background: #d4c5a9; }
			.top-bar {
				display: flex;
				justify-content: flex-end;
				margin-bottom: 1rem;
			}
			.sticky-header {
				position: sticky;
				top: 0;
				z-index: 10;
				background: #faf9f6;
				border-bottom: 1px solid #e0d8c8;
				padding: 0.6rem 0;
				margin: 0 -1rem 1.5rem;
				padding-inline: 1rem;
				display: flex;
				justify-content: center;
				align-items: center;
			}
			.dedication-footer {
				text-align: center;
				margin-top: 3rem;
				padding-top: 1.5rem;
				border-top: 1px solid #e0d8c8;
				color: #888;
				font-size: 0.9rem;
			}
			.eng-toggle {
				padding: 0.25rem 0.6rem;
				font-size: 0.8rem;
				background: #e8e0d0;
				color: #1a1a1a;
				border: none;
				border-radius: 5px;
				cursor: pointer;
				font-family: inherit;
			}
			.eng-toggle:hover { background: #d4c5a9; }
			.eng-toggle.active { background: #8b7355; color: #fff; }
			.translation-toggle {
				display: none;
				margin-right: 0.5rem;
				cursor: pointer;
				color: #4a6fa5;
				font-size: 0.85rem;
				user-select: none;
				border: 1px solid #a8c4e0;
				border-radius: 4px;
				padding: 0.1rem 0.4rem;
			}
			.translation-toggle:hover { background: #eef3f9; }
			.show-english .translation-toggle { display: inline-block; }
			.mishnah-en {
				display: none;
				direction: ltr;
				text-align: left;
				color: #555;
				font-size: 0.8em;
				margin-top: 0.4rem;
				padding-top: 0.4rem;
				border-top: 1px dotted #ddd;
				line-height: 1.6;
			}
			.mishnah-en.open { display: block; }
			.mishnah-en i { font-style: italic; }
			.edit-bar {
				display: none;
				background: #f0ebe0;
				border: 1px solid #d4c5a9;
				border-radius: 8px;
				padding: 0.75rem 1rem;
				margin-bottom: 1.5rem;
			}
			.edit-bar.visible { display: block; }
			.edit-bar .edit-row {
				display: flex;
				gap: 0.5rem;
				margin-bottom: 0.5rem;
			}
			.edit-bar .edit-row:last-child { margin-bottom: 0; }
			.edit-bar input {
				flex: 1;
				padding: 0.5rem 0.75rem;
				font-size: 1rem;
				border: 1px solid #d4c5a9;
				border-radius: 6px;
				font-family: inherit;
				direction: rtl;
			}
			.edit-bar button {
				padding: 0.5rem 1rem;
				font-size: 0.9rem;
				background: #8b7355;
				color: #fff;
				border: none;
				border-radius: 6px;
				cursor: pointer;
				font-family: inherit;
			}
			.edit-bar button:hover { background: #6d5a43; }
			.edit-btn {
				font-size: 0.8rem;
				padding: 0.2rem 0.5rem;
				background: #e8e0d0;
				color: #1a1a1a;
				border: none;
				border-radius: 4px;
				cursor: pointer;
				font-family: inherit;
				margin-right: 0.5rem;
			}
			.edit-btn:hover { background: #d4c5a9; }
		</style>
	</head>
	<body>
		<div class="top-bar">
			<button class="eng-toggle" id="engToggle">EN</button>
		</div>

		<h1 id="mainTitle">לימוד משניות לפי אותיות השם</h1>
		<p class="subtitle" id="subtitle">
			{personName || name}
			<button class="edit-btn" id="editBtn" style="display:none;">✎</button>
		</p>
		<a class="back-link" id="backLink" href="/">← חזרה לחיפוש</a>

		<div class="edit-bar" id="editBar">
			<div class="edit-row">
				<input type="text" id="editName" value={name} placeholder="שם (אותיות)" />
			</div>
			<div class="edit-row">
				<input type="text" id="editPersonName" value={personName || ''} placeholder="שם הנפטר/ת (לעילוי נשמת...)" />
			</div>
			<div class="edit-row">
				<button id="editSaveBtn">שמור</button>
			</div>
		</div>

		<div class="sticky-header">
			<div class="font-bar">
				<button id="fontDown">א-</button>
				<span id="fontLabel">140%</span>
				<button id="fontUp">א+</button>
			</div>
		</div>

		<div id="letters"></div>
		<div id="loading">טוען משניות...</div>
		<div id="results"></div>

		<div id="neshama-section" class="chapter" style="margin-top: 2rem; border: 2px solid #d4c5a9;">
			<div class="chapter-header">
				<span>משנה מקוואות פרק ז׳ ד׳-ז׳ — נשמה</span>
			</div>
			<div id="neshama-content" style="color: #888; padding: 1rem; text-align: right;">טוען...</div>
		</div>

		<footer class="dedication-footer" id="dedication">לעילוי נשמת ר' מרדכי בן יהושע זעליג ריבקין</footer>

		<script define:vars={{ name, letters, personName, pageId }}>
			// Edit functionality
			const editToken = localStorage.getItem(`edit_${pageId}`);
			if (editToken) {
				document.getElementById('editBtn').style.display = 'inline-block';
			}
			document.getElementById('editBtn').addEventListener('click', () => {
				document.getElementById('editBar').classList.toggle('visible');
			});
			document.getElementById('editSaveBtn').addEventListener('click', async () => {
				const newName = document.getElementById('editName').value.trim();
				const newPersonName = document.getElementById('editPersonName').value.trim();
				if (!newName) return;
				const newLetters = [...newName].filter(c => {
					const hebrewLetters = 'אבגדהוזחטיכךלמםנןסעפףצץקרשת';
					return hebrewLetters.includes(c);
				}).join('');
				try {
					const res = await fetch('/api/update', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							id: pageId,
							editToken,
							name: newName,
							letters: newLetters,
							personName: newPersonName || null,
						}),
					});
					const data = await res.json();
					if (data.ok) {
						window.location.reload();
					} else {
						alert(data.error || 'שגיאה');
					}
				} catch {
					alert('שגיאה בשמירה');
				}
			});

			let isEnglish = false;
			const engToggle = document.getElementById('engToggle');
			engToggle.addEventListener('click', () => {
				isEnglish = !isEnglish;
				engToggle.classList.toggle('active');
				document.getElementById('results').classList.toggle('show-english');
				document.getElementById('neshama-section').classList.toggle('show-english');
				const html = document.documentElement;
				if (isEnglish) {
					html.setAttribute('lang', 'en');
					document.getElementById('mainTitle').textContent = 'Mishnah for Yahrtzeit';
					document.getElementById('backLink').textContent = '← Back to search';
					document.getElementById('dedication').textContent = 'L\'ilui Nishmas R\' Mordechai ben Yehoshua Zelig Rivkin';
					engToggle.textContent = 'עב';
				} else {
					html.setAttribute('lang', 'he');
					document.getElementById('mainTitle').textContent = 'לימוד משניות לפי אותיות השם';
					document.getElementById('backLink').textContent = '← חזרה לחיפוש';
					document.getElementById('dedication').textContent = 'לעילוי נשמת ר\' מרדכי בן יהושע זעליג ריבקין';
					engToggle.textContent = 'EN';
				}
			});

			let fontSize = 140;
			const fontLabel = document.getElementById('fontLabel');
			document.getElementById('fontUp').addEventListener('click', () => adjustFont(10));
			document.getElementById('fontDown').addEventListener('click', () => adjustFont(-10));
			function adjustFont(delta) {
				fontSize = Math.max(70, Math.min(200, fontSize + delta));
				document.querySelectorAll('.mishnah').forEach(el => {
					el.style.fontSize = `${fontSize}%`;
				});
				fontLabel.textContent = `${fontSize}%`;
			}

			const LETTER_MAP = {
				'א': { masechet: 'Mishnah_Berakhot', perek: 5, heRef: 'ברכות פרק ה׳' },
				'ב': { masechet: 'Mishnah_Taanit', perek: 4, heRef: 'תענית פרק ד׳' },
				'ג': { masechet: 'Mishnah_Bava_Batra', perek: 10, heRef: 'בבא בתרא פרק י׳' },
				'ד': { masechet: 'Mishnah_Sanhedrin', perek: 1, heRef: 'סנהדרין פרק א׳' },
				'ה': { masechet: 'Mishnah_Berakhot', perek: 2, heRef: 'ברכות פרק ב׳' },
				'ו': { masechet: 'Mishnah_Moed_Katan', perek: 3, heRef: 'מועד קטן פרק ג׳' },
				'ז': { masechet: 'Mishnah_Tahorot', perek: 9, heRef: 'טהרות פרק ט׳' },
				'ח': { masechet: 'Mishnah_Shabbat', perek: 22, heRef: 'שבת פרק כ״ב' },
				'ט': { masechet: 'Mishnah_Yoma', perek: 4, heRef: 'יומא פרק ד׳' },
				'י': { masechet: 'Mishnah_Rosh_Hashanah', perek: 4, heRef: 'ראש השנה פרק ד׳' },
				'כ': { masechet: 'Mishnah_Berakhot', perek: 6, heRef: 'ברכות פרק ו׳' },
				'ך': { masechet: 'Mishnah_Berakhot', perek: 6, heRef: 'ברכות פרק ו׳' },
				'ל': { masechet: 'Mishnah_Sukkah', perek: 4, heRef: 'סוכה פרק ד׳' },
				'מ': { masechet: 'Mishnah_Berakhot', perek: 1, heRef: 'ברכות פרק א׳' },
				'ם': { masechet: 'Mishnah_Berakhot', perek: 1, heRef: 'ברכות פרק א׳' },
				'נ': { masechet: 'Mishnah_Shabbat', perek: 21, heRef: 'שבת פרק כ״א' },
				'ן': { masechet: 'Mishnah_Shabbat', perek: 21, heRef: 'שבת פרק כ״א' },
				'ס': { masechet: 'Mishnah_Sukkah', perek: 1, heRef: 'סוכה פרק א׳' },
				'ע': { masechet: 'Mishnah_Pesachim', perek: 10, heRef: 'פסחים פרק י׳' },
				'פ': { masechet: 'Mishnah_Challah', perek: 2, heRef: 'חלה פרק ב׳' },
				'ף': { masechet: 'Mishnah_Challah', perek: 2, heRef: 'חלה פרק ב׳' },
				'צ': { masechet: 'Mishnah_Parah', perek: 9, heRef: 'פרה פרק ט׳' },
				'ץ': { masechet: 'Mishnah_Parah', perek: 9, heRef: 'פרה פרק ט׳' },
				'ק': { masechet: 'Mishnah_Nedarim', perek: 8, heRef: 'נדרים פרק ח׳' },
				'ר': { masechet: 'Mishnah_Shabbat', perek: 13, heRef: 'שבת פרק י״ג' },
				'ש': { masechet: 'Mishnah_Shabbat', perek: 23, heRef: 'שבת פרק כ״ג' },
				'ת': { masechet: 'Mishnah_Berakhot', perek: 4, heRef: 'ברכות פרק ד׳' },
			};

			const allLetters = [...name].filter(c => LETTER_MAP[c]);
			const seen = new Set();
			const unique = [];
			for (const l of allLetters) {
				const info = LETTER_MAP[l];
				const key = `${info.masechet}.${info.perek}`;
				if (!seen.has(key)) {
					seen.add(key);
					unique.push({ letter: l, ...info });
				}
			}

			const lettersDiv = document.getElementById('letters');
			const resultsDiv = document.getElementById('results');
			const loadingDiv = document.getElementById('loading');

			for (const item of unique) {
				const badge = document.createElement('span');
				badge.className = 'letter-badge';
				badge.textContent = item.letter;
				badge.title = item.heRef;
				badge.addEventListener('click', () => {
					document.querySelectorAll('.letter-badge').forEach(b => b.classList.remove('active'));
					badge.classList.add('active');
					const target = document.getElementById(`chapter-${item.masechet}-${item.perek}`);
					target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
				});
				lettersDiv.appendChild(badge);
			}

			function gematriya(n) {
				const ones = ['', 'א', 'ב', 'ג', 'ד', 'ה', 'ו', 'ז', 'ח', 'ט'];
				const tens = ['', 'י', 'כ', 'ל', 'מ', 'נ', 'ס', 'ע', 'פ', 'צ'];
				if (n <= 0) return '';
				if (n >= 100) return 'ק' + gematriya(n - 100);
				if (n === 15) return 'ט״ו';
				if (n === 16) return 'ט״ז';
				const t = tens[Math.floor(n / 10)];
				const o = ones[n % 10];
				if (t && o) return t + '״' + o;
				return t || o;
			}

			(async () => {
				const results = await Promise.all(
					unique.map(async (item) => {
						try {
							const [mishnahRes, enRes, bartRes] = await Promise.all([
								fetch(`https://www.sefaria.org/api/v3/texts/${item.masechet}.${item.perek}`),
								fetch(`https://www.sefaria.org/api/v3/texts/${item.masechet}.${item.perek}?version=english`),
								fetch(`https://www.sefaria.org/api/v3/texts/Bartenura_on_${item.masechet}.${item.perek}`),
							]);
							const mishnahData = await mishnahRes.json();
							const enData = await enRes.json();
							const bartData = await bartRes.json();
							const heVersion = mishnahData.versions?.find(v => v.language === 'he');
							const enVersion = enData.versions?.find(v => v.language === 'en');
							const bartVersion = bartData.versions?.find(v => v.language === 'he');
							return { ...item, texts: heVersion?.text || [], enTexts: enVersion?.text || [], bartenura: bartVersion?.text || [], error: false };
						} catch {
							return { ...item, texts: [], enTexts: [], bartenura: [], error: true };
						}
					})
				);

				loadingDiv.style.display = 'none';

				let html = '';
				for (const r of results) {
					html += `<div class="chapter" id="chapter-${r.masechet}-${r.perek}">`;
					html += `<div class="chapter-header">
						<span>משנה ${r.heRef}</span>
						<span class="letter-tag">אות ${r.letter}</span>
					</div>`;
					if (r.error) {
						html += `<div class="error">שגיאה בטעינת הפרק</div>`;
					} else if (r.texts.length === 0) {
						html += `<div class="error">לא נמצא טקסט</div>`;
					} else {
						for (let i = 0; i < r.texts.length; i++) {
							const text = r.texts[i].replace(/<[^>]*>/g, '');
							const bartParts = r.bartenura[i] || [];
							const bartId = `bart-${r.masechet}-${r.perek}-${i}`;
							let bartHtml = '';
							if (bartParts.length > 0) {
								bartHtml = `<span class="bartenura-toggle" onclick="document.getElementById('${bartId}').classList.toggle('open');this.textContent=this.textContent==='ברטנורא +'?'ברטנורא −':'ברטנורא +'">ברטנורא +</span>`;
								bartHtml += `<div class="bartenura" id="${bartId}">${bartParts.join(' ')}</div>`;
							}
							const enId = `en-${r.masechet}-${r.perek}-${i}`;
							let enHtml = '';
							if (r.enTexts[i]) {
								enHtml = `<span class="translation-toggle" onclick="document.getElementById('${enId}').classList.toggle('open');this.textContent=this.textContent==='Translation +'?'Translation −':'Translation +'">Translation +</span>`;
								enHtml += `<div class="mishnah-en" id="${enId}">${r.enTexts[i]}</div>`;
							}
							html += `<div class="mishnah"><span class="mishnah-num">${gematriya(i + 1)}.</span> ${text}${enHtml}${bartHtml}</div>`;
						}
					}
					html += `</div>`;
				}
				resultsDiv.innerHTML = html;
			})();

			// Load נשמה section (Mikvaot 7:4-7)
			(async () => {
				try {
					const [mishnahRes, enRes, bartRes] = await Promise.all([
						fetch('https://www.sefaria.org/api/v3/texts/Mishnah_Mikvaot.7'),
						fetch('https://www.sefaria.org/api/v3/texts/Mishnah_Mikvaot.7?version=english'),
						fetch('https://www.sefaria.org/api/v3/texts/Bartenura_on_Mishnah_Mikvaot.7'),
					]);
					const mishnahData = await mishnahRes.json();
					const enData = await enRes.json();
					const bartData = await bartRes.json();
					const heVersion = mishnahData.versions?.find(v => v.language === 'he');
					const enVersion = enData.versions?.find(v => v.language === 'en');
					const bartVersion = bartData.versions?.find(v => v.language === 'he');
					const texts = heVersion?.text || [];
					const enTexts = enVersion?.text || [];
					const bart = bartVersion?.text || [];
					let html = '';
					for (let i = 3; i < Math.min(texts.length, 7); i++) {
						const text = texts[i].replace(/<[^>]*>/g, '');
						const bartParts = bart[i] || [];
						const bartId = `bart-neshama-${i}`;
						let bartHtml = '';
						if (bartParts.length > 0) {
							bartHtml = `<span class="bartenura-toggle" onclick="document.getElementById('${bartId}').classList.toggle('open');this.textContent=this.textContent==='ברטנורא +'?'ברטנורא −':'ברטנורא +'">ברטנורא +</span>`;
							bartHtml += `<div class="bartenura" id="${bartId}">${bartParts.join(' ')}</div>`;
						}
						const enId = `en-neshama-${i}`;
						let enHtml = '';
						if (enTexts[i]) {
							enHtml = `<span class="translation-toggle" onclick="document.getElementById('${enId}').classList.toggle('open');this.textContent=this.textContent==='Translation +'?'Translation −':'Translation +'">Translation +</span>`;
							enHtml += `<div class="mishnah-en" id="${enId}">${enTexts[i]}</div>`;
						}
						html += `<div class="mishnah"><span class="mishnah-num">${gematriya(i + 1)}.</span> ${text}${enHtml}${bartHtml}</div>`;
					}
					document.getElementById('neshama-content').innerHTML = html;
				} catch {
					document.getElementById('neshama-content').innerHTML = '<div class="error">שגיאה בטעינה</div>';
				}
			})();
		</script>
	</body>
</html>

---
import { sql } from '../lib/db';

const { id } = Astro.params;

const rows = await sql`SELECT * FROM saved_links WHERE id = ${id}`;
const record = rows[0];

if (!record) {
  return Astro.redirect('/');
}

const name: string = record.name;
const personName: string | null = record.person_name;
const letters: string = record.letters;
const pageId: string = record.id;
const lang = Astro.request.headers.get('accept-language') || '';
const prefersEnglish = /^en/i.test(lang) && !/he/i.test(lang.split(',')[0]);
---

<html lang="he" dir="rtl" data-prefers-en={prefersEnglish ? 'true' : 'false'}>
	<head>
		<meta charset="utf-8" />

		<meta name="viewport" content="width=device-width" />
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
		<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;700&family=Frank+Ruhl+Libre:wght@400;700&display=swap" rel="stylesheet" />
		<title>לימוד משניות לפי אותיות השם {personName || name}</title>
		<meta property="og:title" content={`משניות אותיות ${name}`} />
		<meta property="og:description" content={`לעילוי נשמת ${personName || name}`} />
		<meta property="og:type" content="website" />
		{record.has_image && <meta property="og:image" content={`${Astro.url.origin}/api/image/${pageId}`} />}
		<meta name="description" content={`משניות אותיות ${name} - לעילוי נשמת ${personName || name}`} />
		<style is:global>
			* { box-sizing: border-box; margin: 0; padding: 0; }
			body {
				font-family: 'Heebo', sans-serif;
				background: #faf9f6;
				color: #1a1a1a;
				padding: 2rem 1rem;
				max-width: 720px;
				margin: 0 auto;
			}
			h1 {
				font-size: 1.8rem;
				text-align: center;
				margin-bottom: 0.5rem;
			}
			.hero-image {
				text-align: center;
				margin-bottom: 1.5rem;
			}
			.hero-image img {
				max-width: 100%;
				max-height: 300px;
				border-radius: 10px;
				border: 1px solid #e0d8c8;
				object-fit: contain;
			}
			.subtitle {
				text-align: center;
				color: #666;
				margin-bottom: 2rem;
				font-size: 1.1rem;
			}
#letters {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-bottom: 2rem;
				justify-content: center;
			}
			.letter-badge {
				background: #e8e0d0;
				padding: 0.4rem 0.8rem;
				border-radius: 6px;
				font-size: 1.1rem;
				cursor: pointer;
				border: 2px solid transparent;
				transition: all 0.15s;
			}
			.letter-badge:hover { border-color: #8b7355; }
			.letter-badge.active {
				background: #8b7355;
				color: #fff;
			}
			#loading {
				text-align: center;
				padding: 2rem;
				color: #888;
			}
			.chapter {
				background: #fff;
				border: 1px solid #e0d8c8;
				border-radius: 10px;
				margin-bottom: 1.5rem;
				overflow: hidden;
			}
			.chapter-header {
				background: #f0ebe0;
				padding: 0.75rem 1rem;
				font-weight: bold;
				font-size: 1.1rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.chapter-header .letter-tag {
				background: #8b7355;
				color: #fff;
				padding: 0.2rem 0.6rem;
				border-radius: 4px;
				font-size: 0.9rem;
			}
			.mishnah {
				padding: 0.75rem 1rem;
				border-bottom: 1px solid #f0ebe0;
				line-height: 1.8;
				font-size: 140%;
				font-family: 'Frank Ruhl Libre', serif;
			}
			.mishnah:last-child { border-bottom: none; }
			.mishnah-num {
				font-weight: bold;
				color: #8b7355;
				margin-left: 0.3rem;
			}
			.bartenura-toggle {
				display: inline-block;
				margin-right: 0.5rem;
				cursor: pointer;
				color: #8b7355;
				font-size: 0.85rem;
				user-select: none;
				border: 1px solid #d4c5a9;
				border-radius: 4px;
				padding: 0.1rem 0.4rem;
			}
			.bartenura-toggle:hover { background: #f0ebe0; }
			.bartenura {
				display: none;
				background: #f9f6ef;
				border-top: 1px dashed #d4c5a9;
				margin-top: 0.5rem;
				padding: 0.6rem 0.8rem;
				line-height: 1.7;
				font-size: 0.82em;
				color: #444;
			}
			.bartenura.open { display: block; }
			.bartenura b { color: #1a1a1a; }
			.error {
				text-align: center;
				color: #c44;
				padding: 1rem;
			}
			.font-bar {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.85rem;
				color: #888;
			}
			.font-bar button {
				padding: 0.25rem 0.6rem;
				font-size: 0.9rem;
				background: #e8e0d0;
				color: #1a1a1a;
				border: none;
				border-radius: 5px;
				min-width: 2rem;
				cursor: pointer;
				font-family: inherit;
			}
			.font-bar button:hover { background: #d4c5a9; }
			.top-bar {
				display: flex;
				justify-content: flex-end;
				gap: 0.5rem;
				margin-bottom: 1rem;
			}
			#settingsBtn {
				background: none;
				font-size: 1.1rem;
				padding: 0.2rem 0.5rem;
				border: 1px solid #d4c5a9;
				color: #8b7355;
			}
			#settingsBtn:hover { background: #f0ebe3; }
			.sticky-header {
				position: sticky;
				top: 0;
				z-index: 10;
				background: #faf9f6;
				border-bottom: 1px solid #e0d8c8;
				padding: 0.6rem 0;
				margin: 0 -1rem 1.5rem;
				padding-inline: 1rem;
				display: flex;
				justify-content: center;
				align-items: center;
			}
			.settings-modal {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0,0,0,0.5);
				z-index: 999;
				justify-content: center;
				align-items: center;
			}
			.settings-modal.open { display: flex; }
			.settings-panel {
				background: #faf9f6;
				border-radius: 10px;
				padding: 1.5rem;
				min-width: 280px;
				max-width: 90vw;
				border: 1px solid #e0d8c8;
			}
			.settings-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1rem;
				font-size: 1.1rem;
				font-weight: 700;
			}
			.settings-close {
				background: none;
				border: none;
				font-size: 1.5rem;
				cursor: pointer;
				color: #666;
				line-height: 1;
			}
			.settings-option {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				cursor: pointer;
				font-size: 1rem;
				padding: 0.5rem 0;
			}
			.settings-option input[type="checkbox"] {
				width: 1.1rem;
				height: 1.1rem;
				accent-color: #8b7355;
			}
			.crop-modal {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0,0,0,0.7);
				z-index: 1000;
				justify-content: center;
				align-items: center;
				flex-direction: column;
			}
			.crop-modal.open { display: flex; }
			.crop-container {
				max-width: 90vw;
				max-height: 70vh;
				background: #fff;
				border-radius: 10px;
				overflow: hidden;
			}
			.crop-container img { max-width: 100%; display: block; }
			.crop-buttons {
				display: flex;
				gap: 1rem;
				margin-top: 1rem;
				justify-content: center;
			}
			.crop-buttons button {
				padding: 0.5rem 1.5rem;
				border: none;
				border-radius: 6px;
				font-size: 1rem;
				cursor: pointer;
				font-family: 'Heebo', sans-serif;
			}
			.crop-confirm { background: #8b7355; color: #fff; }
			.crop-cancel { background: #e8e0d0; color: #1a1a1a; }
			.dedication-footer {
				text-align: center;
				margin-top: 3rem;
				padding-top: 1.5rem;
				border-top: 1px solid #e0d8c8;
				color: #888;
				font-size: 0.9rem;
			}
			.eng-toggle {
				padding: 0.25rem 0.6rem;
				font-size: 0.8rem;
				background: #e8e0d0;
				color: #1a1a1a;
				border: none;
				border-radius: 5px;
				cursor: pointer;
				font-family: inherit;
			}
			.eng-toggle:hover { background: #d4c5a9; }
			.eng-toggle.active { background: #8b7355; color: #fff; }
			.translation-toggle {
				display: none;
				margin-right: 0.5rem;
				cursor: pointer;
				color: #4a6fa5;
				font-size: 0.85rem;
				user-select: none;
				border: 1px solid #a8c4e0;
				border-radius: 4px;
				padding: 0.1rem 0.4rem;
			}
			.translation-toggle:hover { background: #eef3f9; }
			.show-english .translation-toggle { display: inline-block; }
			.mishnah-en {
				display: none;
				direction: ltr;
				text-align: left;
				color: #555;
				font-size: 0.8em;
				margin-top: 0.4rem;
				padding-top: 0.4rem;
				border-top: 1px dotted #ddd;
				line-height: 1.6;
			}
			.mishnah-en.open { display: block; }
			.mishnah-en i { font-style: italic; }
			.edit-bar {
				display: none;
				background: #f0ebe0;
				border: 1px solid #d4c5a9;
				border-radius: 8px;
				padding: 0.75rem 1rem;
				margin-bottom: 1.5rem;
			}
			.edit-bar.visible { display: block; }
			.edit-bar .edit-row {
				display: flex;
				gap: 0.5rem;
				margin-bottom: 0.5rem;
			}
			.edit-bar .edit-row:last-child { margin-bottom: 0; }
			.edit-bar input {
				flex: 1;
				padding: 0.5rem 0.75rem;
				font-size: 1rem;
				border: 1px solid #d4c5a9;
				border-radius: 6px;
				font-family: inherit;
				direction: rtl;
			}
			.edit-bar button {
				padding: 0.5rem 1rem;
				font-size: 0.9rem;
				background: #8b7355;
				color: #fff;
				border: none;
				border-radius: 6px;
				cursor: pointer;
				font-family: inherit;
			}
			.edit-bar button:hover { background: #6d5a43; }
			.edit-btn {
				font-size: 0.8rem;
				padding: 0.2rem 0.5rem;
				background: #e8e0d0;
				color: #1a1a1a;
				border: none;
				border-radius: 4px;
				cursor: pointer;
				font-family: inherit;
				margin-right: 0.5rem;
			}
			.edit-btn:hover { background: #d4c5a9; }
		</style>
	</head>
	<body>
		<div class="top-bar">
			<button class="eng-toggle" id="settingsBtn" title="הגדרות">⚙</button>
			<button class="eng-toggle" id="engToggle">EN</button>
		</div>

		<div class="settings-modal" id="settingsModal">
			<div class="settings-panel">
				<div class="settings-header">
					<span id="settingsTitle">הגדרות</span>
					<button class="settings-close" id="settingsClose">&times;</button>
				</div>
				<label class="settings-option">
					<input type="checkbox" id="firstOnlyCheck" />
					<span id="firstOnlyLabel">הצג רק משנה ראשונה לכל אות</span>
				</label>
				<label class="settings-option">
					<input type="checkbox" id="altChaptersCheck" />
					<span id="altChaptersLabel">פרקים שונים לאותיות כפולות</span>
				</label>
			</div>
		</div>

		{record.has_image && (
			<div class="hero-image">
				<img src={`/api/image/${pageId}`} alt={personName || name} />
			</div>
		)}
		<h1 id="mainTitle">לימוד משניות לפי אותיות השם</h1>
		<p class="subtitle" id="subtitle">
			{personName || name}
			<button class="edit-btn" id="editBtn" style="display:none;">✎</button>
		</p>

		<div class="edit-bar" id="editBar">
			<div class="edit-row">
				<input type="text" id="editName" value={name} placeholder="שם (אותיות)" />
			</div>
			<div class="edit-row">
				<input type="text" id="editPersonName" value={personName || ''} placeholder="שם הנפטר/ת (לעילוי נשמת...)" />
			</div>
			<div class="edit-row">
				<label style="cursor: pointer; color: #8b7355; font-size: 0.9rem;">
					📷 <span id="editImageLabelText">העלה תמונה (עד 100KB)</span>
					<input type="file" id="editImageInput" accept="image/*" style="display: none;" />
				</label>
				<span id="editImageName" style="font-size: 0.85rem; color: #666;"></span>
			</div>
			<div class="edit-row">
				<button id="editSaveBtn">שמור</button>
			</div>
		</div>

		<div class="sticky-header">
			<div class="font-bar">
				<button id="fontDown">א-</button>
				<span id="fontLabel">140%</span>
				<button id="fontUp">א+</button>
			</div>
		</div>

		<div id="letters"></div>
		<div id="loading">טוען משניות...</div>
		<div id="results"></div>

		<div id="neshama-section" class="chapter" style="margin-top: 2rem; border: 2px solid #d4c5a9;">
			<div class="chapter-header">
				<span>משנה אותיות נשמה - מסכת מקוואות פרק ז, משנה ד-ז</span>
			</div>
			<div id="neshama-content" style="color: #888; padding: 1rem; text-align: right;">טוען...</div>
		</div>

		<div class="crop-modal" id="cropModal">
			<div class="crop-container">
				<img id="cropImage" />
			</div>
			<div class="crop-buttons">
				<button class="crop-confirm" id="cropConfirm">אישור</button>
				<button class="crop-cancel" id="cropCancel">ביטול</button>
			</div>
		</div>

		<footer class="dedication-footer" id="dedication">לע"נ ר' מרדכי בן יהושע זעליג ע"ה ולע"נ מרת דוואשא בת ר' מנחם מענדל ע"ה</footer>
		<div class="attribution" id="attribution" style="display:none; text-align:center; color:#999; font-size:0.75rem; margin-top:0.5rem;">English translation: William Davidson Edition, Koren Publishers. CC-BY-NC. Via Sefaria.</div>

		<script define:vars={{ name, letters, personName, pageId }}>
			// Edit functionality
			const editToken = localStorage.getItem(`edit_${pageId}`);
			if (editToken) {
				document.getElementById('editBtn').style.display = 'inline-block';
			}
			document.getElementById('editBtn').addEventListener('click', () => {
				document.getElementById('editBar').classList.toggle('visible');
			});
			const editImageInput = document.getElementById('editImageInput');
			const editImageName = document.getElementById('editImageName');
			const cropModal = document.getElementById('cropModal');
			const cropImage = document.getElementById('cropImage');
			const cropConfirm = document.getElementById('cropConfirm');
			const cropCancel = document.getElementById('cropCancel');
			let editProcessedImage = null;
			let cropper = null;

			function compressCanvas(canvas) {
				return new Promise((resolve, reject) => {
					let quality = 0.85;
					(function tryCompress() {
						canvas.toBlob(blob => {
							if (!blob) return reject(new Error('Canvas export failed'));
							if (blob.size <= 102400 || quality <= 0.1) {
								resolve(blob);
							} else {
								quality -= 0.1;
								tryCompress();
							}
						}, 'image/jpeg', quality);
					})();
				});
			}

			editImageInput.addEventListener('change', () => {
				const file = editImageInput.files?.[0];
				if (!file) { editImageName.textContent = ''; return; }
				cropImage.src = URL.createObjectURL(file);
				cropModal.classList.add('open');
				if (cropper) cropper.destroy();
				cropper = new Cropper(cropImage, {
					aspectRatio: 600 / 315,
					viewMode: 1,
					autoCropArea: 1,
				});
			});

			cropConfirm.addEventListener('click', async () => {
				if (!cropper) return;
				const canvas = cropper.getCroppedCanvas({ width: 600, height: 315 });
				cropper.destroy();
				cropper = null;
				cropModal.classList.remove('open');
				editImageName.textContent = 'מעבד...';
				try {
					editProcessedImage = await compressCanvas(canvas);
					const kb = (editProcessedImage.size / 1024).toFixed(0);
					editImageName.textContent = `${editImageInput.files?.[0]?.name || 'image'} (${kb}KB)`;
				} catch {
					editImageName.textContent = 'שגיאה בעיבוד התמונה';
					editProcessedImage = null;
				}
			});

			cropCancel.addEventListener('click', () => {
				if (cropper) { cropper.destroy(); cropper = null; }
				cropModal.classList.remove('open');
				editImageInput.value = '';
				editImageName.textContent = '';
				editProcessedImage = null;
			});
			document.getElementById('editSaveBtn').addEventListener('click', async () => {
				const newName = document.getElementById('editName').value.trim();
				const newPersonName = document.getElementById('editPersonName').value.trim();
				if (!newName) return;
				const newLetters = [...newName].filter(c => {
					const hebrewLetters = 'אבגדהוזחטיכךלמםנןסעפףצץקרשת';
					return hebrewLetters.includes(c);
				}).join('');
				try {
					const formData = new FormData();
					formData.append('id', pageId);
					formData.append('editToken', editToken);
					formData.append('name', newName);
					formData.append('letters', newLetters);
					formData.append('personName', newPersonName);
					if (editProcessedImage) {
						formData.append('image', editProcessedImage, 'photo.jpg');
					}
					const res = await fetch('/api/update', {
						method: 'POST',
						body: formData,
					});
					const data = await res.json();
					if (data.ok) {
						window.location.reload();
					} else {
						alert(data.error || 'שגיאה');
					}
				} catch {
					alert('שגיאה בשמירה');
				}
			});

			const prefersEnglish = document.documentElement.dataset.prefersEn === 'true';
			let isEnglish = false;
			const engToggle = document.getElementById('engToggle');
			function toggleEnglish() {
				isEnglish = !isEnglish;
				engToggle.classList.toggle('active');
				document.getElementById('results').classList.toggle('show-english');
				document.getElementById('neshama-section').classList.toggle('show-english');
				const html = document.documentElement;
				if (isEnglish) {
					html.setAttribute('lang', 'en');
					document.getElementById('mainTitle').textContent = 'Mishnah for Yahrtzeit';
	
					document.getElementById('attribution').style.display = '';
					engToggle.textContent = 'עב';
				} else {
					html.setAttribute('lang', 'he');
					document.getElementById('mainTitle').textContent = 'לימוד משניות לפי אותיות השם';
					document.getElementById('attribution').style.display = 'none';
					engToggle.textContent = 'EN';
				}
			}
			engToggle.addEventListener('click', toggleEnglish);
			if (prefersEnglish) toggleEnglish();

			const settingsBtn = document.getElementById('settingsBtn');
			const settingsModal = document.getElementById('settingsModal');
			const settingsClose = document.getElementById('settingsClose');
			const firstOnlyCheck = document.getElementById('firstOnlyCheck');

			settingsBtn.addEventListener('click', () => settingsModal.classList.add('open'));
			settingsClose.addEventListener('click', () => settingsModal.classList.remove('open'));
			settingsModal.addEventListener('click', (e) => {
				if (e.target === settingsModal) settingsModal.classList.remove('open');
			});

			firstOnlyCheck.addEventListener('change', () => {
				const firstOnly = firstOnlyCheck.checked;
				document.querySelectorAll('.chapter').forEach(ch => {
					const mishnayot = ch.querySelectorAll('.mishnah');
					mishnayot.forEach((m, i) => {
						m.style.display = (firstOnly && i > 0) ? 'none' : '';
					});
				});
			});

			let fontSize = 140;
			const fontLabel = document.getElementById('fontLabel');
			document.getElementById('fontUp').addEventListener('click', () => adjustFont(10));
			document.getElementById('fontDown').addEventListener('click', () => adjustFont(-10));
			function adjustFont(delta) {
				fontSize = Math.max(70, Math.min(200, fontSize + delta));
				document.querySelectorAll('.mishnah').forEach(el => {
					el.style.fontSize = `${fontSize}%`;
				});
				fontLabel.textContent = `${fontSize}%`;
			}

			const FINAL_MAP = { 'ך': 'כ', 'ם': 'מ', 'ן': 'נ', 'ף': 'פ', 'ץ': 'צ' };
			const hebrewLettersStr = 'אבגדהוזחטיכךלמםנןסעפףצץקרשת';
			const altChaptersCheck = document.getElementById('altChaptersCheck');

			async function loadLetterData(letter, priority) {
				const baseLetter = FINAL_MAP[letter] || letter;
				const res = await fetch(`/data/letters/${baseLetter}-${priority}.json`);
				if (!res.ok) return null;
				return res.json();
			}

			const MASECHET_HE = {
				Mishnah_Berakhot: 'ברכות', Mishnah_Peah: 'פאה', Mishnah_Demai: 'דמאי', Mishnah_Kilayim: 'כלאים', Mishnah_Sheviit: 'שביעית', Mishnah_Terumot: 'תרומות', Mishnah_Maasrot: 'מעשרות', Mishnah_Maaser_Sheni: 'מעשר שני', Mishnah_Challah: 'חלה', Mishnah_Orlah: 'ערלה', Mishnah_Bikkurim: 'ביכורים',
				Mishnah_Shabbat: 'שבת', Mishnah_Eruvin: 'עירובין', Mishnah_Pesachim: 'פסחים', Mishnah_Shekalim: 'שקלים', Mishnah_Yoma: 'יומא', Mishnah_Sukkah: 'סוכה', Mishnah_Beitzah: 'ביצה', Mishnah_Rosh_Hashanah: 'ראש השנה', Mishnah_Taanit: 'תענית', Mishnah_Megillah: 'מגילה', Mishnah_Moed_Katan: 'מועד קטן', Mishnah_Chagigah: 'חגיגה',
				Mishnah_Yevamot: 'יבמות', Mishnah_Ketubot: 'כתובות', Mishnah_Nedarim: 'נדרים', Mishnah_Nazir: 'נזיר', Mishnah_Sotah: 'סוטה', Mishnah_Gittin: 'גיטין', Mishnah_Kiddushin: 'קידושין',
				Mishnah_Bava_Kamma: 'בבא קמא', Mishnah_Bava_Metzia: 'בבא מציעא', Mishnah_Bava_Batra: 'בבא בתרא', Mishnah_Sanhedrin: 'סנהדרין', Mishnah_Makkot: 'מכות', Mishnah_Shevuot: 'שבועות', Mishnah_Eduyot: 'עדויות', Mishnah_Avodah_Zarah: 'עבודה זרה', Mishnah_Avot: 'אבות', Mishnah_Horayot: 'הוריות',
				Mishnah_Zevachim: 'זבחים', Mishnah_Menachot: 'מנחות', Mishnah_Chullin: 'חולין', Mishnah_Bekhorot: 'בכורות', Mishnah_Arakhin: 'ערכין', Mishnah_Temurah: 'תמורה', Mishnah_Keritot: 'כריתות', Mishnah_Meilah: 'מעילה', Mishnah_Tamid: 'תמיד', Mishnah_Middot: 'מידות', Mishnah_Kinnim: 'קינים',
				Mishnah_Kelim: 'כלים', Mishnah_Oholot: 'אהלות', Mishnah_Negaim: 'נגעים', Mishnah_Parah: 'פרה', Mishnah_Tahorot: 'טהרות', Mishnah_Mikvaot: 'מקוואות', Mishnah_Niddah: 'נדה', Mishnah_Makhshirin: 'מכשירין', Mishnah_Zavim: 'זבים', Mishnah_Tevul_Yom: 'טבול יום', Mishnah_Yadayim: 'ידים', Mishnah_Oktzin: 'עוקצין',
			};

			function masechetHeRef(masechet, perek) {
				return `מסכת ${MASECHET_HE[masechet] || masechet} פרק ${gematriya(perek)}`;
			}

			const lettersDiv = document.getElementById('letters');
			const resultsDiv = document.getElementById('results');
			const loadingDiv = document.getElementById('loading');

			function gematriya(n) {
				const ones = ['', 'א', 'ב', 'ג', 'ד', 'ה', 'ו', 'ז', 'ח', 'ט'];
				const tens = ['', 'י', 'כ', 'ל', 'מ', 'נ', 'ס', 'ע', 'פ', 'צ'];
				if (n <= 0) return '';
				if (n >= 100) return 'ק' + gematriya(n - 100);
				if (n === 15) return 'ט״ו';
				if (n === 16) return 'ט״ז';
				const t = tens[Math.floor(n / 10)];
				const o = ones[n % 10];
				if (t && o) return t + '״' + o;
				return t || o;
			}

			async function loadChapters() {
				const allLetters = [...name].filter(c => hebrewLettersStr.includes(c));
				const useAlt = altChaptersCheck.checked;
				const letterCount = {};
				const items = allLetters.map(l => {
					const base = FINAL_MAP[l] || l;
					letterCount[base] = (letterCount[base] || 0) + 1;
					const priority = useAlt ? letterCount[base] : 1;
					return { letter: l, baseLetter: base, priority: Math.min(priority, 4) };
				});

				lettersDiv.innerHTML = '';
				loadingDiv.style.display = 'block';
				resultsDiv.innerHTML = '';

				const results = await Promise.all(
					items.map(async (item, idx) => {
						try {
							const data = await loadLetterData(item.letter, item.priority);
							if (!data) throw new Error('No data');
							return { letter: item.letter, masechet: data.masechet, perek: data.perek, heRef: data.name, texts: data.mishnayot, enTexts: data.english, bartenura: data.bartenura, error: false, idx };
						} catch {
							return { letter: item.letter, masechet: '', perek: 0, heRef: '', texts: [], enTexts: [], bartenura: [], error: true, idx };
						}
					})
				);

				for (const r of results) {
					const badge = document.createElement('span');
					badge.className = 'letter-badge';
					badge.textContent = r.letter;
					badge.title = r.heRef;
					badge.addEventListener('click', () => {
						document.querySelectorAll('.letter-badge').forEach(b => b.classList.remove('active'));
						badge.classList.add('active');
						const target = document.getElementById(`chapter-${r.idx}`);
						target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
					});
					lettersDiv.appendChild(badge);
				}

				loadingDiv.style.display = 'none';

				let html = '';
				for (const r of results) {
					html += `<div class="chapter" id="chapter-${r.idx}">`;
					html += `<div class="chapter-header">
						<span>${masechetHeRef(r.masechet, r.perek)}</span>
						<span class="letter-tag">אות ${r.letter}</span>
					</div>`;
					if (r.error) {
						html += `<div class="error">שגיאה בטעינת הפרק</div>`;
					} else if (r.texts.length === 0) {
						html += `<div class="error">לא נמצא טקסט</div>`;
					} else {
						for (let i = 0; i < r.texts.length; i++) {
							const text = r.texts[i].replace(/<[^>]*>/g, '');
							const bartParts = r.bartenura[i] || [];
							const bartId = `bart-${r.idx}-${i}`;
							let bartHtml = '';
							if (bartParts.length > 0) {
								bartHtml = `<span class="bartenura-toggle" onclick="document.getElementById('${bartId}').classList.toggle('open');this.textContent=this.textContent==='ברטנורא +'?'ברטנורא −':'ברטנורא +'">ברטנורא +</span>`;
								bartHtml += `<div class="bartenura" id="${bartId}">${bartParts.join(' ')}</div>`;
							}
							const enId = `en-${r.idx}-${i}`;
							let enHtml = '';
							if (r.enTexts[i]) {
								enHtml = `<span class="translation-toggle" onclick="document.getElementById('${enId}').classList.toggle('open');this.textContent=this.textContent==='Translation +'?'Translation −':'Translation +'">Translation +</span>`;
								enHtml += `<div class="mishnah-en" id="${enId}">${r.enTexts[i]}</div>`;
							}
							html += `<div class="mishnah"><span class="mishnah-num">${gematriya(i + 1)}.</span> ${text}${enHtml}${bartHtml}</div>`;
						}
					}
					html += `</div>`;
				}
				resultsDiv.innerHTML = html;
			}

			altChaptersCheck.addEventListener('change', loadChapters);
			loadChapters();

			// Load נשמה section (Mikvaot 7:4-7)
			(async () => {
				try {
					const [mishnahRes, enRes, bartRes] = await Promise.all([
						fetch('https://www.sefaria.org/api/v3/texts/Mishnah_Mikvaot.7'),
						fetch('https://www.sefaria.org/api/v3/texts/Mishnah_Mikvaot.7?version=english'),
						fetch('https://www.sefaria.org/api/v3/texts/Bartenura_on_Mishnah_Mikvaot.7'),
					]);
					const mishnahData = await mishnahRes.json();
					const enData = await enRes.json();
					const bartData = await bartRes.json();
					const heVersion = mishnahData.versions?.find(v => v.language === 'he');
					const enVersion = enData.versions?.find(v => v.language === 'en');
					const bartVersion = bartData.versions?.find(v => v.language === 'he');
					const texts = heVersion?.text || [];
					const enTexts = enVersion?.text || [];
					const bart = bartVersion?.text || [];
					let html = '';
					for (let i = 3; i < Math.min(texts.length, 7); i++) {
						const text = texts[i].replace(/<[^>]*>/g, '');
						const bartParts = bart[i] || [];
						const bartId = `bart-neshama-${i}`;
						let bartHtml = '';
						if (bartParts.length > 0) {
							bartHtml = `<span class="bartenura-toggle" onclick="document.getElementById('${bartId}').classList.toggle('open');this.textContent=this.textContent==='ברטנורא +'?'ברטנורא −':'ברטנורא +'">ברטנורא +</span>`;
							bartHtml += `<div class="bartenura" id="${bartId}">${bartParts.join(' ')}</div>`;
						}
						const enId = `en-neshama-${i}`;
						let enHtml = '';
						if (enTexts[i]) {
							enHtml = `<span class="translation-toggle" onclick="document.getElementById('${enId}').classList.toggle('open');this.textContent=this.textContent==='Translation +'?'Translation −':'Translation +'">Translation +</span>`;
							enHtml += `<div class="mishnah-en" id="${enId}">${enTexts[i]}</div>`;
						}
						html += `<div class="mishnah"><span class="mishnah-num">${gematriya(i + 1)}.</span> ${text}${enHtml}${bartHtml}</div>`;
					}
					document.getElementById('neshama-content').innerHTML = html;
				} catch {
					document.getElementById('neshama-content').innerHTML = '<div class="error">שגיאה בטעינה</div>';
				}
			})();
		</script>
	</body>
</html>

---
const lang = Astro.request.headers.get('accept-language') || '';
const prefersEnglish = /^en/i.test(lang) && !/he/i.test(lang.split(',')[0]);
---

<html lang="he" dir="rtl" data-prefers-en={prefersEnglish ? 'true' : 'false'}>
	<head>
		<meta charset="utf-8" />

		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;700&family=Libertinus+Serif&display=swap" rel="stylesheet" />
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
		<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
		<title>לימוד משניות לפי אותיות השם</title>
		<style is:global>
			* { box-sizing: border-box; margin: 0; padding: 0; }
			body {
				font-family: 'Heebo', sans-serif;
				background: #faf9f6;
				color: #1a1a1a;
				padding: 2rem 1rem;
				max-width: 720px;
				margin: 0 auto;
			}
			h1 {
				font-size: 1.8rem;
				text-align: center;
				margin-bottom: 0.5rem;
			}
			.subtitle {
				text-align: center;
				color: #666;
				margin-bottom: 2rem;
				font-size: 0.95rem;
			}
			.input-row {
				display: flex;
				gap: 0.5rem;
				margin-bottom: 1.5rem;
			}
			input[type="text"] {
				flex: 1;
				padding: 0.75rem 1rem;
				font-size: 1.2rem;
				border: 2px solid #d4c5a9;
				border-radius: 8px;
				font-family: inherit;
				direction: rtl;
				background: #fff;
			}
			input[type="text"]:focus {
				outline: none;
				border-color: #8b7355;
			}
			button {
				padding: 0.75rem 1.5rem;
				font-size: 1.1rem;
				background: #8b7355;
				color: #fff;
				border: none;
				border-radius: 8px;
				cursor: pointer;
				font-family: inherit;
			}
			button:hover { background: #6d5a43; }
			#letters {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-bottom: 2rem;
				justify-content: center;
			}
			.letter-badge {
				background: #e8e0d0;
				padding: 0.4rem 0.8rem;
				border-radius: 6px;
				font-size: 1.1rem;
				cursor: pointer;
				border: 2px solid transparent;
				transition: all 0.15s;
			}
			.letter-badge:hover { border-color: #8b7355; }
			.letter-badge.active {
				background: #8b7355;
				color: #fff;
			}
			#loading {
				text-align: center;
				padding: 2rem;
				color: #888;
				display: none;
			}
			.chapter {
				background: #fff;
				border: 1px solid #e0d8c8;
				border-radius: 10px;
				margin-bottom: 1.5rem;
				overflow: hidden;
			}
			.chapter-header {
				background: #f0ebe0;
				padding: 0.75rem 1rem;
				font-weight: bold;
				font-size: 1.1rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.chapter-header .letter-tag {
				background: #8b7355;
				color: #fff;
				padding: 0.2rem 0.6rem;
				border-radius: 4px;
				font-size: 0.9rem;
			}
			.mishnah {
				padding: 0.75rem 1rem;
				border-bottom: 1px solid #f0ebe0;
				line-height: 1.8;
				font-size: 140%;
				font-family: 'Libertinus Serif', serif;
			}
			.mishnah:last-child { border-bottom: none; }
			.mishnah-num {
				font-weight: bold;
				color: #8b7355;
				margin-left: 0.3rem;
			}
			.bartenura-toggle {
				display: inline-block;
				margin-right: 0.5rem;
				cursor: pointer;
				color: #8b7355;
				font-size: 0.85rem;
				user-select: none;
				border: 1px solid #d4c5a9;
				border-radius: 4px;
				padding: 0.1rem 0.4rem;
			}
			.bartenura-toggle:hover { background: #f0ebe0; }
			.bartenura {
				display: none;
				background: #f9f6ef;
				border-top: 1px dashed #d4c5a9;
				margin-top: 0.5rem;
				padding: 0.6rem 0.8rem;
				line-height: 1.7;
				font-size: 0.82em;
				color: #444;
			}
			.bartenura.open { display: block; }
			.bartenura b { color: #1a1a1a; }
			.no-results {
				text-align: center;
				color: #999;
				padding: 3rem 1rem;
				font-size: 1.1rem;
			}
			.error {
				text-align: center;
				color: #c44;
				padding: 1rem;
			}
			#saveSection {
				display: none;
				text-align: center;
				margin-bottom: 1.5rem;
			}
			#saveSection .save-row {
				display: flex;
				gap: 0.5rem;
				justify-content: center;
				align-items: center;
				flex-wrap: wrap;
			}
			#saveSection input {
				max-width: 350px;
			}
			.save-btn {
				background: #4a7c59;
			}
			.save-btn:hover { background: #3a6247; }
			#savedLink {
				display: none;
				text-align: center;
				margin-bottom: 1.5rem;
				padding: 1rem;
				background: #e8f5e9;
				border-radius: 8px;
			}
			#savedLink a {
				color: #2e7d32;
				font-weight: bold;
				word-break: break-all;
			}
			.copy-btn {
				font-size: 0.9rem;
				padding: 0.4rem 0.8rem;
				background: #4a7c59;
				margin-right: 0.5rem;
			}
			.top-bar {
				display: flex;
				justify-content: flex-end;
				gap: 0.5rem;
				margin-bottom: 1rem;
			}
			#settingsBtn {
				background: none;
				font-size: 1.1rem;
				padding: 0.2rem 0.5rem;
				border: 1px solid #d4c5a9;
				color: #8b7355;
			}
			#settingsBtn:hover { background: #f0ebe3; }
			.settings-modal {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0,0,0,0.5);
				z-index: 999;
				justify-content: center;
				align-items: center;
			}
			.settings-modal.open { display: flex; }
			.settings-panel {
				background: #faf9f6;
				border-radius: 10px;
				padding: 1.5rem;
				min-width: 280px;
				max-width: 90vw;
				border: 1px solid #e0d8c8;
			}
			.settings-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1rem;
				font-size: 1.1rem;
				font-weight: 700;
			}
			.settings-close {
				background: none;
				border: none;
				font-size: 1.5rem;
				cursor: pointer;
				color: #666;
				line-height: 1;
			}
			.settings-option {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				cursor: pointer;
				font-size: 1rem;
				padding: 0.5rem 0;
			}
			.settings-option input[type="checkbox"] {
				width: 1.1rem;
				height: 1.1rem;
				accent-color: #8b7355;
			}
			.crop-modal {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0,0,0,0.7);
				z-index: 1000;
				justify-content: center;
				align-items: center;
				flex-direction: column;
			}
			.crop-modal.open { display: flex; }
			.crop-container {
				max-width: 90vw;
				max-height: 70vh;
				background: #fff;
				border-radius: 10px;
				overflow: hidden;
			}
			.crop-container img { max-width: 100%; display: block; }
			.crop-buttons {
				display: flex;
				gap: 1rem;
				margin-top: 1rem;
				justify-content: center;
			}
			.crop-buttons button {
				padding: 0.5rem 1.5rem;
				border: none;
				border-radius: 6px;
				font-size: 1rem;
				cursor: pointer;
				font-family: 'Heebo', sans-serif;
			}
			.crop-confirm { background: #8b7355; color: #fff; }
			.crop-cancel { background: #e8e0d0; color: #1a1a1a; }
			.dedication-footer {
				text-align: center;
				margin-top: 3rem;
				padding-top: 1.5rem;
				border-top: 1px solid #e0d8c8;
				color: #888;
				font-size: 0.9rem;
			}
			.eng-toggle {
				padding: 0.25rem 0.6rem;
				font-size: 0.8rem;
				background: #e8e0d0;
				color: #1a1a1a;
				border: none;
				border-radius: 5px;
				cursor: pointer;
				font-family: inherit;
			}
			.eng-toggle:hover { background: #d4c5a9; }
			.eng-toggle.active { background: #8b7355; color: #fff; }
			.translation-toggle {
				display: none;
				margin-right: 0.5rem;
				cursor: pointer;
				color: #4a6fa5;
				font-size: 0.85rem;
				user-select: none;
				border: 1px solid #a8c4e0;
				border-radius: 4px;
				padding: 0.1rem 0.4rem;
			}
			.translation-toggle:hover { background: #eef3f9; }
			.show-english .translation-toggle { display: inline-block; }
			.mishnah-en {
				display: none;
				direction: ltr;
				text-align: left;
				color: #555;
				font-size: 0.8em;
				margin-top: 0.4rem;
				padding-top: 0.4rem;
				border-top: 1px dotted #ddd;
				line-height: 1.6;
			}
			.mishnah-en.open { display: block; }
			.mishnah-en i { font-style: italic; }
		</style>
	</head>
	<body>
		<div class="top-bar">
			<button class="eng-toggle" id="settingsBtn" title="הגדרות">⚙</button>
			<button class="eng-toggle" id="engToggle">EN</button>
		</div>

		<div class="settings-modal" id="settingsModal">
			<div class="settings-panel">
				<div class="settings-header">
					<span id="settingsTitle">הגדרות</span>
					<button class="settings-close" id="settingsClose">&times;</button>
				</div>
				<label class="settings-option">
					<input type="checkbox" id="firstOnlyCheck" />
					<span id="firstOnlyLabel">הצג רק משנה ראשונה לכל אות</span>
				</label>
			</div>
		</div>

		<h1 id="mainTitle">לימוד משניות לפי אותיות השם</h1>
		<p class="subtitle" id="subtitle">הקלד שם בעברית — כל אות מחזירה את פרק המשנה המתאים</p>

		<div class="input-row">
			<input type="text" id="nameInput" placeholder="הקלד שם..." autofocus />
			<button id="searchBtn">הצג</button>
		</div>

		<div id="saveSection">
			<div class="save-row">
				<input type="text" id="personNameInput" placeholder="שם הנפטר/ת (לעילוי נשמת...)" />
			</div>
			<div class="save-row" style="margin-top: 0.5rem;">
				<label id="imageLabel" style="cursor: pointer; color: #8b7355; font-size: 0.9rem;">
					📷 <span id="imageLabelText">העלה תמונה (עד 100KB)</span>
					<input type="file" id="imageInput" accept="image/*" style="display: none;" />
				</label>
				<span id="imageName" style="font-size: 0.85rem; color: #666;"></span>
			</div>
			<div class="save-row" style="margin-top: 0.5rem;">
				<button class="save-btn" id="saveBtn">שמור קישור</button>
			</div>
		</div>

		<div id="savedLink">
			<span id="savedLinkLabel">הקישור נשמר: </span>
			<a id="savedLinkUrl" href="#" target="_blank"></a>
			<button class="copy-btn" id="copyBtn">העתק</button>
		</div>

		<div id="letters" dir="rtl"></div>
		<div id="loading">טוען משניות...</div>
		<div id="results" dir="rtl"></div>

		<div id="neshama-section" class="chapter" style="margin-top: 2rem; border: 2px solid #d4c5a9; display: none;">
			<div class="chapter-header">
				<span>משנה אותיות נשמה - מסכת מקוואות פרק ז, משנה ד-ז</span>
			</div>
			<div id="neshama-content" style="color: #888; padding: 1rem; text-align: right;">טוען...</div>
		</div>

		<div class="crop-modal" id="cropModal">
			<div class="crop-container">
				<img id="cropImage" />
			</div>
			<div class="crop-buttons">
				<button class="crop-confirm" id="cropConfirm">אישור</button>
				<button class="crop-cancel" id="cropCancel">ביטול</button>
			</div>
		</div>

		<footer class="dedication-footer" id="dedication">לע"נ ר' מרדכי בן יהושע זעליג ע"ה ולע"נ מרת דוואשא בת ר' מנחם מענדל ע"ה</footer>


		<script>
			const prefersEnglish = document.documentElement.dataset.prefersEn === 'true';
			let isEnglish = false;
			const engToggle = document.getElementById('engToggle')!;

			function toggleEnglish() {
				isEnglish = !isEnglish;
				engToggle.classList.toggle('active');
				document.getElementById('results')!.classList.toggle('show-english');
				const html = document.documentElement;
				if (isEnglish) {
					html.setAttribute('lang', 'en');
					document.body.style.direction = 'ltr';
					document.getElementById('mainTitle')!.textContent = 'Mishnah for Yahrtzeit';
					document.getElementById('subtitle')!.textContent = 'Enter a Hebrew name — each letter returns a corresponding Mishnah chapter';
					(document.getElementById('nameInput') as HTMLInputElement).placeholder = 'Enter name using Hebrew letters';
					(document.getElementById('nameInput') as HTMLInputElement).style.direction = 'ltr';
					document.getElementById('searchBtn')!.textContent = 'Go';
					(document.getElementById('personNameInput') as HTMLInputElement).placeholder = 'L\'iluy Nishmas Dedication';
					(document.getElementById('personNameInput') as HTMLInputElement).style.direction = 'ltr';
					document.getElementById('saveBtn')!.textContent = 'Save Link';
					document.getElementById('savedLinkLabel')!.textContent = 'Link saved: ';
					document.getElementById('copyBtn')!.textContent = 'Copy';
					document.getElementById('imageLabelText')!.textContent = 'Upload image (max 100KB)';
	
					engToggle.textContent = 'עב';
				} else {
					html.setAttribute('lang', 'he');
					document.body.style.direction = 'rtl';
					document.getElementById('mainTitle')!.textContent = 'לימוד משניות לפי אותיות השם';
					document.getElementById('subtitle')!.textContent = 'הקלד שם בעברית — כל אות מחזירה את פרק המשנה המתאים';
					(document.getElementById('nameInput') as HTMLInputElement).placeholder = 'הקלד שם...';
					(document.getElementById('nameInput') as HTMLInputElement).style.direction = 'rtl';
					document.getElementById('searchBtn')!.textContent = 'הצג';
					(document.getElementById('personNameInput') as HTMLInputElement).placeholder = 'שם הנפטר/ת (לעילוי נשמת...)';
					(document.getElementById('personNameInput') as HTMLInputElement).style.direction = 'rtl';
					document.getElementById('saveBtn')!.textContent = 'שמור קישור';
					document.getElementById('savedLinkLabel')!.textContent = 'הקישור נשמר: ';
					document.getElementById('copyBtn')!.textContent = 'העתק';
					document.getElementById('imageLabelText')!.textContent = 'העלה תמונה (עד 100KB)';
	
					engToggle.textContent = 'EN';
				}
			}
			engToggle.addEventListener('click', toggleEnglish);
			if (prefersEnglish) toggleEnglish();

			const settingsBtn = document.getElementById('settingsBtn')!;
			const settingsModal = document.getElementById('settingsModal')!;
			const settingsClose = document.getElementById('settingsClose')!;
			const firstOnlyCheck = document.getElementById('firstOnlyCheck') as HTMLInputElement;

			settingsBtn.addEventListener('click', () => settingsModal.classList.add('open'));
			settingsClose.addEventListener('click', () => settingsModal.classList.remove('open'));
			settingsModal.addEventListener('click', (e) => {
				if (e.target === settingsModal) settingsModal.classList.remove('open');
			});

			firstOnlyCheck.addEventListener('change', () => {
				const firstOnly = firstOnlyCheck.checked;
				document.querySelectorAll('.chapter').forEach(ch => {
					const mishnayot = ch.querySelectorAll('.mishnah');
					mishnayot.forEach((m, i) => {
						(m as HTMLElement).style.display = (firstOnly && i > 0) ? 'none' : '';
					});
				});
			});

			const LETTER_MAP: Record<string, { masechet: string; perek: number; heRef: string }> = {
				'א': { masechet: 'Mishnah_Berakhot', perek: 5, heRef: 'ברכות פרק ה׳' },
				'ב': { masechet: 'Mishnah_Taanit', perek: 4, heRef: 'תענית פרק ד׳' },
				'ג': { masechet: 'Mishnah_Bava_Batra', perek: 10, heRef: 'בבא בתרא פרק י׳' },
				'ד': { masechet: 'Mishnah_Sanhedrin', perek: 1, heRef: 'סנהדרין פרק א׳' },
				'ה': { masechet: 'Mishnah_Berakhot', perek: 2, heRef: 'ברכות פרק ב׳' },
				'ו': { masechet: 'Mishnah_Moed_Katan', perek: 3, heRef: 'מועד קטן פרק ג׳' },
				'ז': { masechet: 'Mishnah_Tahorot', perek: 9, heRef: 'טהרות פרק ט׳' },
				'ח': { masechet: 'Mishnah_Shabbat', perek: 22, heRef: 'שבת פרק כ״ב' },
				'ט': { masechet: 'Mishnah_Yoma', perek: 4, heRef: 'יומא פרק ד׳' },
				'י': { masechet: 'Mishnah_Rosh_Hashanah', perek: 4, heRef: 'ראש השנה פרק ד׳' },
				'כ': { masechet: 'Mishnah_Berakhot', perek: 6, heRef: 'ברכות פרק ו׳' },
				'ך': { masechet: 'Mishnah_Berakhot', perek: 6, heRef: 'ברכות פרק ו׳' },
				'ל': { masechet: 'Mishnah_Sukkah', perek: 4, heRef: 'סוכה פרק ד׳' },
				'מ': { masechet: 'Mishnah_Berakhot', perek: 1, heRef: 'ברכות פרק א׳' },
				'ם': { masechet: 'Mishnah_Berakhot', perek: 1, heRef: 'ברכות פרק א׳' },
				'נ': { masechet: 'Mishnah_Shabbat', perek: 21, heRef: 'שבת פרק כ״א' },
				'ן': { masechet: 'Mishnah_Shabbat', perek: 21, heRef: 'שבת פרק כ״א' },
				'ס': { masechet: 'Mishnah_Sukkah', perek: 1, heRef: 'סוכה פרק א׳' },
				'ע': { masechet: 'Mishnah_Pesachim', perek: 10, heRef: 'פסחים פרק י׳' },
				'פ': { masechet: 'Mishnah_Challah', perek: 2, heRef: 'חלה פרק ב׳' },
				'ף': { masechet: 'Mishnah_Challah', perek: 2, heRef: 'חלה פרק ב׳' },
				'צ': { masechet: 'Mishnah_Parah', perek: 9, heRef: 'פרה פרק ט׳' },
				'ץ': { masechet: 'Mishnah_Parah', perek: 9, heRef: 'פרה פרק ט׳' },
				'ק': { masechet: 'Mishnah_Nedarim', perek: 8, heRef: 'נדרים פרק ח׳' },
				'ר': { masechet: 'Mishnah_Shabbat', perek: 13, heRef: 'שבת פרק י״ג' },
				'ש': { masechet: 'Mishnah_Shabbat', perek: 23, heRef: 'שבת פרק כ״ג' },
				'ת': { masechet: 'Mishnah_Berakhot', perek: 4, heRef: 'ברכות פרק ד׳' },
			};

			const nameInput = document.getElementById('nameInput') as HTMLInputElement;
			const searchBtn = document.getElementById('searchBtn')!;
			const lettersDiv = document.getElementById('letters')!;
			const resultsDiv = document.getElementById('results')!;
			const loadingDiv = document.getElementById('loading')!;
			const saveSection = document.getElementById('saveSection')!;
			const personNameInput = document.getElementById('personNameInput') as HTMLInputElement;
			const saveBtn = document.getElementById('saveBtn')!;
			const savedLinkDiv = document.getElementById('savedLink')!;
			const savedLinkUrl = document.getElementById('savedLinkUrl') as HTMLAnchorElement;
			const copyBtn = document.getElementById('copyBtn')!;

			let currentName = '';
			let currentLetters = '';

			nameInput.addEventListener('keydown', (e) => {
				if (e.key === 'Enter') search();
			});
			searchBtn.addEventListener('click', search);
			saveBtn.addEventListener('click', save);
			copyBtn.addEventListener('click', () => {
				navigator.clipboard.writeText(savedLinkUrl.href);
				copyBtn.textContent = 'הועתק!';
				setTimeout(() => copyBtn.textContent = 'העתק', 2000);
			});

			async function search() {
				const name = nameInput.value.trim();
				if (!name) return;

				currentName = name;
				savedLinkDiv.style.display = 'none';

				const letters = [...name].filter(c => LETTER_MAP[c]);
				if (letters.length === 0) {
					resultsDiv.innerHTML = '<div class="no-results">לא נמצאו אותיות עבריות בשם</div>';
					lettersDiv.innerHTML = '';
					saveSection.style.display = 'none';
					return;
				}

				currentLetters = letters.join('');

				const unique = letters.map(l => ({ letter: l, ...LETTER_MAP[l] }));

				lettersDiv.innerHTML = '';
				for (const item of unique) {
					const badge = document.createElement('span');
					badge.className = 'letter-badge';
					badge.textContent = item.letter;
					badge.title = item.heRef;
					badge.addEventListener('click', () => {
						document.querySelectorAll('.letter-badge').forEach(b => b.classList.remove('active'));
						badge.classList.add('active');
						const target = document.getElementById(`chapter-${item.masechet}-${item.perek}`);
						target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
					});
					lettersDiv.appendChild(badge);
				}

				loadingDiv.style.display = 'block';
				resultsDiv.innerHTML = '';
				saveSection.style.display = 'none';

				const results = await Promise.all(
					unique.map(async (item) => {
						try {
							const [mishnahRes, enRes, bartRes] = await Promise.all([
								fetch(`https://www.sefaria.org/api/v3/texts/${item.masechet}.${item.perek}`),
								fetch(`https://www.sefaria.org/api/v3/texts/${item.masechet}.${item.perek}?version=english`),
								fetch(`https://www.sefaria.org/api/v3/texts/Bartenura_on_${item.masechet}.${item.perek}`),
							]);
							const mishnahData = await mishnahRes.json();
							const enData = await enRes.json();
							const bartData = await bartRes.json();
							const heVersion = mishnahData.versions?.find((v: any) => v.language === 'he');
							const enVersion = enData.versions?.find((v: any) => v.language === 'en');
							const texts: string[] = heVersion?.text || [];
							const enTexts: string[] = enVersion?.text || [];
							const bartVersion = bartData.versions?.find((v: any) => v.language === 'he');
							const bartenura: string[][] = bartVersion?.text || [];
							return { ...item, texts, enTexts, bartenura, error: false };
						} catch {
							return { ...item, texts: [] as string[], enTexts: [] as string[], bartenura: [] as string[][], error: true };
						}
					})
				);

				loadingDiv.style.display = 'none';
				saveSection.style.display = 'block';

				let html = '';
				for (const r of results) {
					html += `<div class="chapter" id="chapter-${r.masechet}-${r.perek}">`;
					html += `<div class="chapter-header">
						<span>משנה ${r.heRef}</span>
						<span class="letter-tag">אות ${r.letter}</span>
					</div>`;
					if (r.error) {
						html += `<div class="error">שגיאה בטעינת הפרק</div>`;
					} else if (r.texts.length === 0) {
						html += `<div class="error">לא נמצא טקסט</div>`;
					} else {
						for (let i = 0; i < r.texts.length; i++) {
							const text = r.texts[i].replace(/<[^>]*>/g, '');
							const bartParts = r.bartenura[i] || [];
							const bartId = `bart-${r.masechet}-${r.perek}-${i}`;
							let bartHtml = '';
							if (bartParts.length > 0) {
								bartHtml = `<span class="bartenura-toggle" onclick="document.getElementById('${bartId}').classList.toggle('open');this.textContent=this.textContent==='ברטנורא +'?'ברטנורא −':'ברטנורא +'">ברטנורא +</span>`;
								bartHtml += `<div class="bartenura" id="${bartId}">${bartParts.join(' ')}</div>`;
							}
							const enId = `en-${r.masechet}-${r.perek}-${i}`;
							let enHtml = '';
							if (r.enTexts[i]) {
								enHtml = `<span class="translation-toggle" onclick="document.getElementById('${enId}').classList.toggle('open');this.textContent=this.textContent==='Translation +'?'Translation −':'Translation +'">Translation +</span>`;
								enHtml += `<div class="mishnah-en" id="${enId}">${r.enTexts[i]}</div>`;
							}
							html += `<div class="mishnah"><span class="mishnah-num">${gematriya(i + 1)}.</span> ${text}${enHtml}${bartHtml}</div>`;
						}
					}
					html += `</div>`;
				}
				resultsDiv.innerHTML = html;
				loadNeshama();
			}

			async function loadNeshama() {
				const section = document.getElementById('neshama-section')!;
				const content = document.getElementById('neshama-content')!;
				section.style.display = '';
				content.innerHTML = 'טוען...';
				try {
					const [mishnahRes, enRes, bartRes] = await Promise.all([
						fetch('https://www.sefaria.org/api/v3/texts/Mishnah_Mikvaot.7'),
						fetch('https://www.sefaria.org/api/v3/texts/Mishnah_Mikvaot.7?version=english'),
						fetch('https://www.sefaria.org/api/v3/texts/Bartenura_on_Mishnah_Mikvaot.7'),
					]);
					const mishnahData = await mishnahRes.json();
					const enData = await enRes.json();
					const bartData = await bartRes.json();
					const heVersion = mishnahData.versions?.find((v: any) => v.language === 'he');
					const enVersion = enData.versions?.find((v: any) => v.language === 'en');
					const bartVersion = bartData.versions?.find((v: any) => v.language === 'he');
					const texts: string[] = heVersion?.text || [];
					const enTexts: string[] = enVersion?.text || [];
					const bart: string[][] = bartVersion?.text || [];
					let html = '';
					for (let i = 3; i < Math.min(texts.length, 7); i++) {
						const text = texts[i].replace(/<[^>]*>/g, '');
						const bartParts = bart[i] || [];
						const bartId = `bart-neshama-${i}`;
						let bartHtml = '';
						if (bartParts.length > 0) {
							bartHtml = `<span class="bartenura-toggle" onclick="document.getElementById('${bartId}').classList.toggle('open');this.textContent=this.textContent==='ברטנורא +'?'ברטנורא −':'ברטנורא +'">ברטנורא +</span>`;
							bartHtml += `<div class="bartenura" id="${bartId}">${bartParts.join(' ')}</div>`;
						}
						const enId = `en-neshama-${i}`;
						let enHtml = '';
						if (enTexts[i]) {
							enHtml = `<span class="translation-toggle" onclick="document.getElementById('${enId}').classList.toggle('open');this.textContent=this.textContent==='Translation +'?'Translation −':'Translation +'">Translation +</span>`;
							enHtml += `<div class="mishnah-en" id="${enId}">${enTexts[i]}</div>`;
						}
						html += `<div class="mishnah"><span class="mishnah-num">${gematriya(i + 1)}.</span> ${text}${enHtml}${bartHtml}</div>`;
					}
					content.innerHTML = html;
				} catch {
					content.innerHTML = '<div class="error">שגיאה בטעינה</div>';
				}
			}

			const imageInput = document.getElementById('imageInput') as HTMLInputElement;
			const imageName = document.getElementById('imageName')!;
			const cropModal = document.getElementById('cropModal')!;
			const cropImage = document.getElementById('cropImage') as HTMLImageElement;
			const cropConfirm = document.getElementById('cropConfirm')!;
			const cropCancel = document.getElementById('cropCancel')!;
			let processedImage: Blob | null = null;
			let cropper: any = null;

			function compressCanvas(canvas: HTMLCanvasElement): Promise<Blob> {
				return new Promise((resolve, reject) => {
					let quality = 0.85;
					(function tryCompress() {
						canvas.toBlob(blob => {
							if (!blob) return reject(new Error('Canvas export failed'));
							if (blob.size <= 102400 || quality <= 0.1) {
								resolve(blob);
							} else {
								quality -= 0.1;
								tryCompress();
							}
						}, 'image/jpeg', quality);
					})();
				});
			}

			imageInput.addEventListener('change', () => {
				const file = imageInput.files?.[0];
				if (!file) { imageName.textContent = ''; return; }
				cropImage.src = URL.createObjectURL(file);
				cropModal.classList.add('open');
				if (cropper) cropper.destroy();
				cropper = new (window as any).Cropper(cropImage, {
					aspectRatio: 600 / 315,
					viewMode: 1,
					autoCropArea: 1,
				});
			});

			cropConfirm.addEventListener('click', async () => {
				if (!cropper) return;
				const canvas = cropper.getCroppedCanvas({ width: 600, height: 315 });
				cropper.destroy();
				cropper = null;
				cropModal.classList.remove('open');
				imageName.textContent = 'מעבד...';
				try {
					processedImage = await compressCanvas(canvas);
					const kb = (processedImage.size / 1024).toFixed(0);
					imageName.textContent = `${imageInput.files?.[0]?.name || 'image'} (${kb}KB)`;
				} catch {
					imageName.textContent = 'שגיאה בעיבוד התמונה';
					processedImage = null;
				}
			});

			cropCancel.addEventListener('click', () => {
				if (cropper) { cropper.destroy(); cropper = null; }
				cropModal.classList.remove('open');
				imageInput.value = '';
				imageName.textContent = '';
				processedImage = null;
			});

			async function save() {
				saveBtn.textContent = 'שומר...';
				try {
					const formData = new FormData();
					formData.append('name', currentName);
					formData.append('letters', currentLetters);
					formData.append('personName', personNameInput.value.trim());
					if (processedImage) {
						formData.append('image', processedImage, 'photo.jpg');
					}
					const res = await fetch('/api/save', {
						method: 'POST',
						body: formData,
					});
					const data = await res.json();
					if (data.editToken) {
						localStorage.setItem(`edit_${data.id}`, data.editToken);
					}
					const url = `${window.location.origin}/${data.id}`;
					savedLinkUrl.href = url;
					savedLinkUrl.textContent = url;
					savedLinkDiv.style.display = 'block';
				} catch {
					alert('שגיאה בשמירה');
				}
				saveBtn.textContent = 'שמור קישור';
			}

			function gematriya(n: number): string {
				const ones = ['', 'א', 'ב', 'ג', 'ד', 'ה', 'ו', 'ז', 'ח', 'ט'];
				const tens = ['', 'י', 'כ', 'ל', 'מ', 'נ', 'ס', 'ע', 'פ', 'צ'];
				if (n <= 0) return '';
				if (n >= 100) return 'ק' + gematriya(n - 100);
				if (n === 15) return 'ט״ו';
				if (n === 16) return 'ט״ז';
				const t = tens[Math.floor(n / 10)];
				const o = ones[n % 10];
				if (t && o) return t + '״' + o;
				return t || o;
			}
		</script>
	</body>
</html>
